# ===================
# Directus CMS
# ===================
DIRECTUS_URL=http://localhost:8055
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me

# ===================
# PostgreSQL Database
# ===================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_DATABASE=blogg_cms

# ===================
# Express Server
# ===================
SERVER_PORT=5000
NODE_ENV=development

# ===================
# Directus Static Token (for server-to-Directus calls)
# Generate one in Directus Admin > Settings > Access Tokens
# ===================
DIRECTUS_STATIC_TOKEN=your-static-token-here
